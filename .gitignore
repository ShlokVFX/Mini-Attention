# show only tracked dirs — add new top-level dirs here to track them
*
!kernels/
!kernels/**
!experiments/
!experiments/**
!figures/
!figures/**
!notes/
!notes/**
!tests/
!tests/**
!Readme.md
!.gitignore
!setup.sh
!pyproject.toml
!uv.lock

# drop compiled/cache inside tracked dirs
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.ptx
**/*.cubin
**/*.fatbin
**/*.egg-info/

# Build artifacts — JIT compilation cache (torch.utils.cpp_extension.load)
kernels/flash_attn/cuda/build/
**/*.so
**/*.o
**/.ninja_deps
**/.ninja_log
**/build.ninja

# Scratch / PR drafts
pr_body.md
