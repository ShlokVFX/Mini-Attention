# show only: kernels/ experiments/ models/ figures/ Readme.md
*
!kernels/
!kernels/**
!experiments/
!experiments/**
!models/
!models/**
!figures/
!figures/**
!Readme.md
!.gitignore
!setup.sh
!_staging_kv_quant_repo/
!_staging_kv_quant_repo/**

# drop compiled/cache inside tracked dirs
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.ptx
**/*.cubin
**/*.fatbin
**/*.egg-info/

# Build artifacts — JIT compilation cache (torch.utils.cpp_extension.load)
kernels/flash_attn/cuda/build/
**/*.so
**/*.o
**/.ninja_deps
**/.ninja_log
**/build.ninja

# Scratch / PR drafts
pr_body.md
